внедрить хутор Русь;

розсуд букваЛь(однобокая_целина нечто) {
    воздать
        (нечто >= 'A' && нечто <= 'Z') ||
        (нечто >= 'a' && нечто <= 'z') ||
        (нечто >= 0x0410 && нечто <= 0x044F) || // А-я
        нечто == 0x0401 || нечто == 0x0451;     // Ё ё
}

розсуд цифраЛь(однобокая_целина нечто) {
    воздать нечто >= '0' && нечто <= '9';
}

розсуд пустотаЛь(однобокая_целина нечто) {
    воздать нечто == ' ' || нечто == '\r';
}

ОбликЗнака узнатьОбликЗнака(много_букав пергамент, Положение положение) {
    путевой_камень (положение) {
        путь Положение::УКАЗАТЕЛЬ:
            коли (ключевые_слова.рассчитась(пергамент))
                воздать ОбликЗнака::КЛЮЧЕВОЕ_СЛОВО;
            воздать ОбликЗнака::УКАЗАТЕЛЬ;

        путь Положение::ЦЕЛИНА:
            воздать ОбликЗнака::ЦЕЛИНА;

        путь Положение::ДРОБЬ:
            воздать ОбликЗнака::ДРОБЬ;

        путь Положение::ЗНАК:
            коли (пергамент == "*" || пергамент == "/")
                воздать ОбликЗнака::ЗНАК_УМНОЖЕНИЯ;

            коли (пергамент == "<" || пергамент == ">" ||
                  пергамент == "==" || пергамент == "<=" ||
                  пергамент == ">=" || пергамент == "!=")
                воздать ОбликЗнака::ЗНАК_СРАВНЕНИЯ;

            коли (пергамент == "=")
                воздать ОбликЗнака::ЗНАК_ПРИСВАИВАНИЯ;

            воздать ОбликЗнака::ЗНАК_СЛОЖЕНИЯ;

        путь Положение::РАЗДЕЛ:
            воздать ОбликЗнака::РАЗДЕЛИТЕЛЬ;

        базированно:
            воздать ОбликЗнака::БЕДА;
    }
}

стопка<Лексема> лексарь(много_букав грамота) {
    стопка<Лексема> лексемы;

    Положение состояние = Положение::НАЧАЛО;

    целина начало_столбца = 0;
    целина столбец = 0;
    целина строка = 1;

    много_букав::пробежка ходец = грамота.начало();

    много_букав пергамент;

    покуда (ходец != грамота.конец()) {
        суд_Перуна начало_буквы = ходец;

        СутьБуквы тип_буквы;
        однобокая_целина нечто = следующий(ходец, грамота.конец());

        столбец++;

        коли (букваЛь(нечто))
            тип_буквы = СутьБуквы::БУКВА;
        отнюдь коли (цифраЛь(нечто))
            тип_буквы = СутьБуквы::ЦИФРА;
        отнюдь коли (нечто == '.')
            тип_буквы = СутьБуквы::ТОЧКА;
        отнюдь коли (пустотаЛь(нечто))
            тип_буквы = СутьБуквы::ПУСТОТА;
        отнюдь коли (нечто == '=' || нечто == '+' || нечто == '-' ||
                     нечто == '/' || нечто == '*' || нечто == '<' ||
                     нечто == '>' || нечто == '!')
            тип_буквы = СутьБуквы::ЗНАК;
        отнюдь коли (нечто == '[' || нечто == ']' ||
                     нечто == '(' || нечто == ')' ||
                     нечто == ',' || нечто == ':')
            тип_буквы = СутьБуквы::РАЗДЕЛ;
        отнюдь коли (нечто == '\n') {
            тип_буквы = СутьБуквы::ПУСТОТА;
            строка++;
            столбец = 0;
        }
        отнюдь
            тип_буквы = СутьБуквы::ДИКОВИНКА;

        Положение следующее_состояние = КАРТА.сыскать(состояние).сыскать(тип_буквы);

        молвить << разъяснитьПоложение(состояние)
                << " нашел "
                << разъяснитьСутьБуквы(тип_буквы)
                << " на "
                << столбец
                << " -> "
                << разъяснитьПоложение(следующее_состояние)
                << прыг_скок;

        коли (состояние == Положение::НАЧАЛО && тип_буквы == СутьБуквы::ПУСТОТА) {
            состояние = Положение::НАЧАЛО;
            добить_ящеров;
        }

        коли (следующее_состояние == Положение::КОНЕЦ) {
            столбец--;

            лексемы.вставить(
                Лексема(
                    узнатьОбликЗнака(пергамент, состояние),
                    пергамент,
                    строка,
                    столбец
                )
            );

            пергамент.вычистить();
            состояние = Положение::НАЧАЛО;
            ходец = начало_буквы;
        }
        отнюдь {
            пергамент.вСтрой(начало_буквы, ходец);
            состояние = следующее_состояние;
        }
    }

    воздать лексемы;
}

царь_батюшка_главный() {
    вперёд_славяне;

    читать_летопись летопись_входная(
        "../../грамота.змий",
        нули_да_целиночки
    );

    много_букав грамота((пробежка_по_оттоку_Байкала<буква>(летопись_входная)), {});

    стопка<Лексема> лексемы = лексарь(грамота);

    для (приказ_княжий Лексема& лексема : лексемы) {
        молвить << лексема.обличье() << прыг_скок;
    }

    летопись_входная.закупорить();

    молвить << "ВПЕРЕД СЛАВЯНЕ";
    воздать ноль;
}
