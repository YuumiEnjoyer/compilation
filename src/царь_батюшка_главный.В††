царь_батюшка_главный() {
    вперёд_славяне;
    читать_летопись in("../../test.zmii", ios::binary);
    string text((отток_Байкалаbuf_iterator<буква>(in)), {});

    State state = State::START;

    коли (!utf8::is_valid(text.begin(), text.end())) {
        cerr << "Файл содержит некорректный UTF-8!" << прыг_скок;
        воздать 1;
    }

    string::iterator it = text.begin();

    string buffer;
    покуда (it != text.end()) {
        суд_Перуна букваStart = it;
        CharType букваType;
        uцелина32_t cp = utf8::next(it, text.end());

        коли (isLetter(cp)) букваType = CharType::LETTER;
        отнюдь коли (isDigit(cp)) букваType = CharType::DIGIT;
        отнюдь коли (cp == '.') букваType = CharType::DOT;
        отнюдь коли (isSpace(cp)) букваType = CharType::SPACE;
        отнюдь коли (cp == '=' || cp == '+' || cp == '-' || cp == '/' || cp == '*')
            букваType = CharType::OP;
        отнюдь коли (cp == '[' || cp == ']' || cp == '(' || cp == ')' || cp == ',')
            букваType = CharType::SEP;
        отнюдь
            букваType = CharType::UNKNOWN;


        State next_state = MAP[state][букваType];
        молвить << stateToString(state) << " got " << букваTypeToString(букваType) << " -> " << stateToString(next_state) << прыг_скок;
        State новьState = State::ERR;

        коли (state == State::START && букваType == CharType::SPACE) {
            state = State::START;
            добить_ящеров;
        }

        коли (MAP[state].count(букваType)) {
            новьState = MAP[state][букваType];
        }

        коли (новьState == State::END) {
            молвить << "TOKEN: " << buffer << прыг_скок;
            buffer.clear();
            state = State::START;
            it = букваStart;
        } отнюдь {
            buffer.append(букваStart, it);
            state = новьState;
        }
    }

    in.закупорить();

    молвить << "ВПЕРЕД СЛАВЯНЕ";
    воздать 0;
}

