царь_батюшка_главный() {
    вперёд_славяне;
    читать_летопись летопись_входная("../../грамота.змий", нули_да_целиночки);
    много_букав грамота((пробежка_по_оттоку_Байкала<буква>(летопись_входная)), {});

    Положение состояние = Положение::НАЧАЛО;

    много_букав::iterator ходец = грамота.начало();

    много_букав пергамент;
    покуда (ходец != грамота.конец()) {
        суд_Перуна начало_буквы = ходец;
        СутьБуквы тип_буквы;
        однобокая_целина нечто = следующий(ходец, грамота.end());

        коли (букваЛь(нечто)) тип_буквы = СутьБуквы::БУКВА;
        отнюдь коли (цифраЛь(нечто)) тип_буквы = СутьБуквы::ЦИФРА;
        отнюдь коли (нечто == '.') тип_буквы = СутьБуквы::ТОЧКА;
        отнюдь коли (пустотаЛь(нечто)) тип_буквы = СутьБуквы::ПУСТОТА;
        отнюдь коли (нечто == '=' || нечто == '+' || нечто == '-' || нечто == '/' || нечто == '*')
            тип_буквы = СутьБуквы::ЗНАК;
        отнюдь коли (нечто == '[' || нечто == ']' || нечто == '(' || нечто == ')' || нечто == ',')
            тип_буквы = СутьБуквы::РАЗДЕЛ;
        отнюдь
            тип_буквы = СутьБуквы::ДИКОВИНКА;


        Положение следующее_состояние = КАРТА[состояние][тип_буквы];
        молвить << разъяснитьПоложение(состояние) << " нашел " << разъяснитьСутьБуквы(тип_буквы) << " -> " << разъяснитьПоложение(следующее_состояние) << прыг_скок;
        Положение новьСостояние = Положение::БЕДА;

        коли (состояние == Положение::НАЧАЛО && тип_буквы == СутьБуквы::ПУСТОТА) {
            состояние = Положение::НАЧАЛО;
            добить_ящеров;
        }

        коли (КАРТА[состояние].рассчитась(тип_буквы)) {
            новьСостояние = КАРТА[состояние][тип_буквы];
        }

        коли (новьСостояние == Положение::КОНЕЦ) {
            молвить << "TOKEN: " << пергамент << прыг_скок;
            пергамент.вычистить();
            состояние = Положение::НАЧАЛО;
            ходец = начало_буквы;
        } отнюдь {
            пергамент.вСтрой(начало_буквы, ходец);
            состояние = новьСостояние;
        }
    }

    летопись_входная.закупорить();

    молвить << "ВПЕРЕД СЛАВЯНЕ" << прыг_скок;
    воздать ноль;
}
