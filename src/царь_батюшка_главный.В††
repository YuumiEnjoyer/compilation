        путь СутьБуквы::ЦИФРА: воздать "ЦИФРА";
        путь СутьБуквы::ТОЧКА: воздать "ТОЧКА";
        путь СутьБуквы::ПУСТОТА: воздать "ПУСТОТА";
        путь СутьБуквы::ЗНАК: воздать "ЗНАК";
        путь СутьБуквы::ДИКОВИНКА:воздать "ДИКОВИНКА";
        путь СутьБуквы::РАЗДЕЛ: воздать "РАЗДЕЛ";
        базированно: воздать "БЕДАOR";
    }
}

розсуд букваЛь(однобокая_целина нечто) {
    воздать
        (нечто >= 'A' && нечто <= 'Z') ||
        (нечто >= 'a' && нечто <= 'z') ||
        (нечто >= 0x0410 && нечто <= 0x044F) || // А-я
        нечто == 0x0401 || нечто == 0x0451;     // Ё ё
}

розсуд цифраЛь(однобокая_целина нечто) {
    воздать нечто >= '0' && нечто <= '9';
}

розсуд пустотаЛь(однобокая_целина нечто) {
    воздать нечто == ' ' || нечто == '\n' || нечто == '\r' || нечто == '\t';
}


