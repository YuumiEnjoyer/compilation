много_букав разъяснитьПоложение(Положение положение) {
    путевой_камень (положение) {
        путь Положение::НАЧАЛО: воздать "НАЧАЛО";
        путь Положение::УКАЗАТЕЛЬ: воздать "УКАЗАТЕЛЬ";
        путь Положение::ЦЕЛИНА: воздать "ЦЕЛИНА";
        путь Положение::ДРОБЬ_РАЗДЕЛ: воздать "ДРОБЬ_РАЗДЕЛ";
        путь Положение::ДРОБЬ: воздать "ДРОБЬ";
        путь Положение::ЗНАК: воздать "ЗНАК";
        путь Положение::КОНЕЦ: воздать "КОНЕЦ";
        путь Положение::БЕДА: воздать "БЕДА";
        путь Положение::РАЗДЕЛ: воздать "РАЗДЕЛ";
        базированно: воздать "БЕДА";
    }
}
