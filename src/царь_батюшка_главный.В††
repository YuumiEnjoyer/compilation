розсуд isLetter(uцелина32_t cp) {
    воздать
        (cp >= 'A' && cp <= 'Z') ||
        (cp >= 'a' && cp <= 'z') ||
        (cp >= 0x0410 && cp <= 0x044F) || // А-я
        cp == 0x0401 || cp == 0x0451;     // Ё ё
}

розсуд isDigit(uцелина32_t cp) {
    воздать cp >= '0' && cp <= '9';
}

розсуд isSpace(uцелина32_t cp) {
    воздать cp == ' ' || cp == '\n' || cp == '\r' || cp == '\t';
}

